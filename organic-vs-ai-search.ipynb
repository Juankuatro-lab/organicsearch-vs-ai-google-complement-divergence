import pandas as pd
import numpy as np
import io
import warnings
import re
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.decomposition import TruncatedSVD
import hdbscan
import plotly.express as px
from google.colab import files
warnings.filterwarnings('ignore')

CLICKS_PERCENTILE        = 0.25
AI_PERCENTILE            = 0.75


# Upload
print('Upload your two GSC export files (standard + AI):')
uploaded = files.upload()

# Auto-detect files
GSC_FILE = AI_FILE = None
for fname, content in uploaded.items():
    xl = pd.ExcelFile(io.BytesIO(content))
    if 'Queries' in xl.sheet_names:
        GSC_FILE = fname
    else:
        AI_FILE = fname

if not GSC_FILE or not AI_FILE:
    names = list(uploaded.keys())
    GSC_FILE, AI_FILE = sorted(names)

print(f'GSC Standard : {GSC_FILE}')
print(f'GSC AI       : {AI_FILE}')

# Load
gsc    = pd.read_excel(io.BytesIO(uploaded[GSC_FILE]), sheet_name='Pages')
gsc_ai = pd.read_excel(io.BytesIO(uploaded[AI_FILE]),  sheet_name='Pages')

# Rename columns
gsc    = gsc.rename(columns={'Top pages':'page','Clicks':'gsc_clicks','Impressions':'gsc_impressions','CTR':'gsc_ctr','Position':'gsc_position'})
gsc_ai = gsc_ai.rename(columns={'Top pages':'page','Impressions':'ai_impressions'})

# Impression share
total_gsc = gsc['gsc_impressions'].sum()
total_ai  = gsc_ai['ai_impressions'].sum()
gsc['gsc_impression_share']   = gsc['gsc_impressions']   / total_gsc
gsc_ai['ai_impression_share'] = gsc_ai['ai_impressions'] / total_ai

# Overlap metrics
overlap = set(gsc['page']).intersection(set(gsc_ai['page']))
overlap_gsc_impr = gsc.loc[gsc['page'].isin(overlap), 'gsc_impressions'].sum()
overlap_ai_impr  = gsc_ai.loc[gsc_ai['page'].isin(overlap), 'ai_impressions'].sum()

# AI vs GSC impression share
ai_vs_gsc_share = (total_ai / total_gsc) * 100

# Overlap % of pages (overlap / union of all unique pages)
total_unique_pages = len(set(gsc['page']).union(set(gsc_ai['page'])))
overlap_pct_pages  = len(overlap) / total_unique_pages * 100

print('=' * 55)
print('  IMPRESSION SHARE SUMMARY')
print('=' * 55)
print(f'  Total GSC impressions     : {total_gsc:>12,.0f}')
print(f'  Total GSC AI impressions  : {total_ai:>12,.0f}')
print()
print(f'  AI impression share vs GSC impression share: {ai_vs_gsc_share:>11.1f}%')
print(f'  (SUM AI impressions / SUM GSC impressions x 100)')
print()
print(f'  Overlapping pages         : {len(overlap):>12,.0f}  ({overlap_pct_pages:.1f}% of all unique pages)')
print(f'  GSC-only pages            : {len(set(gsc["page"]) - overlap):>12,.0f}')
print(f'  AI-only pages             : {len(set(gsc_ai["page"]) - overlap):>12,.0f}')
print()
print('=' * 55)

# Merge (full outer join)
merged = pd.merge(gsc, gsc_ai[['page','ai_impressions','ai_impression_share']], on='page', how='outer')
for col in ['gsc_clicks','gsc_impressions','gsc_ctr','gsc_position','gsc_impression_share','ai_impressions','ai_impression_share']:
    merged[col] = merged[col].fillna(0)

merged['in_gsc']    = merged['gsc_impressions'] > 0
merged['in_gsc_ai'] = merged['ai_impressions']  > 0

# Zero-click thresholds
both = merged['in_gsc'] & merged['in_gsc_ai']
clicks_threshold = merged.loc[both, 'gsc_clicks'].quantile(CLICKS_PERCENTILE)
ai_threshold     = merged.loc[both, 'ai_impressions'].quantile(AI_PERCENTILE)

# Segmentation
def assign_segment(r):
    ig, ia = r['in_gsc'], r['in_gsc_ai']
    if ig and ia and r['gsc_clicks'] <= clicks_threshold and r['ai_impressions'] >= ai_threshold:
        return 'zero_click_ai'
    elif ig and ia:  return 'user_ai_signals'
    elif ig:         return 'gsc_only'
    elif ia:         return 'gsc_ai_only'

merged['segment'] = merged.apply(assign_segment, axis=1)
merged['segment_label'] = merged['segment'].map({
    'user_ai_signals' : 'User & AI signals (GSC + AI)',
    'gsc_only'        : 'GSC only (BOFU / Technical gaps?)',
    'gsc_ai_only'     : 'GSC AI only (TOFU / AI-first?)',
    'zero_click_ai'   : 'Close to Zero-click AI pages',
})

# ── ZERO-CLICK SUMMARY ────────────────────────────────────────────────────────
zero_click_count = (merged['segment'] == 'zero_click_ai').sum()
zero_click_pct   = zero_click_count / len(merged) * 100
print(f'  Close to Zero-click AI pages : {zero_click_count:,}  ({zero_click_pct:.1f}% of all pages)')
# ─────────────────────────────────────────────────────────────────────────────


# ── HDBSCAN CLUSTERING FOR GSC ONLY & GSC AI ONLY ────────────────────────────

def extract_path(url):
    url = re.sub(r'https?://[^/]+', '', url)
    url = re.sub(r'\.(html|htm|php)$', '', url)
    url = url.strip('/')
    return re.sub(r'[-/]', ' ', url).strip()

def run_clustering(df, impression_col, segment_name):

    df = df.copy()
    df['path_tokens'] = df['page'].apply(extract_path)

    tfidf = TfidfVectorizer(ngram_range=(1, 2), min_df=1)
    tfidf_matrix = tfidf.fit_transform(df['path_tokens'])

    n_components = min(10, tfidf_matrix.shape[1] - 1, tfidf_matrix.shape[0] - 1)
    svd = TruncatedSVD(n_components=n_components, random_state=42)
    reduced = svd.fit_transform(tfidf_matrix)

    clusterer = hdbscan.HDBSCAN(min_cluster_size=3, min_samples=1, metric='euclidean')
    df['cluster'] = clusterer.fit_predict(reduced)

    def get_cluster_label(cluster_id, cluster_df):
        if cluster_id == -1:
            return 'uncategorised'
        tokens = ' '.join(cluster_df['path_tokens'].tolist())
        word_freq = pd.Series(tokens.split()).value_counts()
        stopwords = {'html','www','co','uk'}
        word_freq = word_freq[~word_freq.index.isin(stopwords)]
        return word_freq.index[0] if len(word_freq) > 0 else f'cluster_{cluster_id}'

    cluster_labels = {}
    for cid in df['cluster'].unique():
        cluster_labels[cid] = get_cluster_label(cid, df[df['cluster'] == cid])

    df['cluster_label'] = df['cluster'].map(cluster_labels)

    ohe = pd.get_dummies(df['cluster_label'], prefix='category').astype(int)
    df = pd.concat([df, ohe], axis=1)

    chart_data = (
        df.groupby('cluster_label')[impression_col]
        .sum()
        .reset_index()
        .sort_values(impression_col, ascending=False)
    )
    chart_data.columns = ['category', 'impressions']

    return df, chart_data

# Run clustering on each segment
gsc_only_df      = merged[merged['segment'] == 'gsc_only'].copy()
gsc_ai_only_df   = merged[merged['segment'] == 'gsc_ai_only'].copy()
zero_click_df    = merged[merged['segment'] == 'zero_click_ai'].copy()  # ── NEW

gsc_only_clustered,    gsc_only_chart    = run_clustering(gsc_only_df,    'gsc_impressions', 'GSC Only (BOFU / technical gaps?)')
gsc_ai_only_clustered, gsc_ai_only_chart = run_clustering(gsc_ai_only_df, 'ai_impressions',  'GSC AI Only (TOFU / AI-first?)')
zero_click_clustered,  zero_click_chart  = run_clustering(zero_click_df,  'gsc_impressions', 'Zero-click AI pages')


# ── PLOTLY CHARTS ─────────────────────────────────────────────────────────────

fig_gsc = px.bar(
    gsc_only_chart.head(25),
    x='impressions',
    y='category',
    orientation='h',
    title='GSC Pages Not in AI features',
    labels={'impressions': 'GSC Impressions', 'category': 'Category'},
    color='impressions',
    color_continuous_scale='Blues',
    text='impressions',
)
fig_gsc.update_traces(texttemplate='%{text:,.0f}', textposition='outside')
fig_gsc.update_layout(yaxis={'categoryorder': 'total ascending'}, coloraxis_showscale=False)
fig_gsc.show()

fig_ai = px.bar(
    gsc_ai_only_chart.head(25),
    x='impressions',
    y='category',
    orientation='h',
    title='GSC Pages Only in AI features',
    labels={'impressions': 'AI Impressions', 'category': 'Category'},
    color='impressions',
    color_continuous_scale='Oranges',
    text='impressions',
)
fig_ai.update_traces(texttemplate='%{text:,.0f}', textposition='outside')
fig_ai.update_layout(yaxis={'categoryorder': 'total ascending'}, coloraxis_showscale=False)
fig_ai.show()


# ── EXPORT ────────────────────────────────────────────────────────────────────
EXPORT_COLS = ['page', 'gsc_clicks', 'gsc_impressions', 'in_gsc', 'in_gsc_ai', 'segment', 'segment_label']

def slim(df, sort_col):
    cols = [c for c in EXPORT_COLS if c in df.columns]
    return df[cols].sort_values(sort_col, ascending=False)

exports = {
    'full_page_export_.csv'       : slim(merged, 'gsc_impressions'),
    'gsc_ai_user_ai_signals.csv' : slim(merged[merged['segment'] == 'user_ai_signals'], 'gsc_impressions'),
    'gsc_ai_gsc_only.csv'        : slim(gsc_only_clustered, 'gsc_impressions'),
    'gsc_ai_ai_only.csv'         : slim(gsc_ai_only_clustered, 'gsc_impressions'),
}

for filename, df in exports.items():
    df.to_csv(filename, index=False)
    files.download(filename)
    print(f'Exported → {filename}')
     

